# Скопируйте в .env и заполните. Файл .env в git не коммитится.

# Обязательно для админки (/admin)
ADMIN_USERNAME=your_login
# Вариант A (продакшен): хеш bcrypt — сгенерируйте: python scripts/hash_admin_password.py
ADMIN_PASSWORD_HASH=
# Вариант B (только локально): открытый пароль (в проде лучше только хеш)
ADMIN_PASSWORD=

# Секрет для JWT (на проде задайте длинную случайную строку)
SECRET_KEY=

# Опционально
# DATABASE_URL=sqlite+aiosqlite:///./data.db
# GITHUB_USERNAME=
